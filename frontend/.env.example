# ── API URLs (baked into the build — must set before docker build) ───────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Payments (public keys only) ──────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX

# ── JWT (server-side only — used by Next.js API proxy routes) ────────────
# Same value as backend JWT_PRIVATE_KEY — never exposed to browser
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----
JWT_ALGORITHM=RS256
JWT_ISSUER=quickhire.services
JWT_AUDIENCE=quickhire-api
